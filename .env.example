# CryptoTaxKE environment variables.
# Copy this file to `.env` and fill in your own values.
# The app requires ALCHEMY_API_KEY for on-chain import.

# Alchemy API key — enables real on-chain transaction import.
# Get one free at https://dashboard.alchemy.com
ALCHEMY_API_KEY=

# --- AI (pick ONE — Groq is free and recommended for testing) ---

# Groq — FREE tier, no credit card. Best for capstone demo & chat testing.
# Sign up at https://console.groq.com and create an API key.
GROQ_API_KEY=

# DeepSeek — very cheap; new accounts often get free credits (Chinese provider).
# https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# OpenAI — paid after free trial credits run out.
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Optional: override the default model for your provider.
# AI_MODEL=llama-3.3-70b-versatile

# Postgres connection string (with pgvector) — used for persistence and RAG.
# A free database is available at https://neon.tech
DATABASE_URL=
