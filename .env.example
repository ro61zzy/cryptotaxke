# CryptoTaxKE environment variables.
# Copy this file to `.env` and fill in your own values.
# The app runs in a limited "demo mode" (sample data, no AI) if these are unset.

# Alchemy API key — enables real on-chain transaction import.
# Get one free at https://dashboard.alchemy.com
ALCHEMY_API_KEY=

# OpenAI API key — enables plain-English explanations, classification, and chat.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Postgres connection string (with pgvector) — used for persistence and RAG.
# A free database is available at https://neon.tech
DATABASE_URL=
